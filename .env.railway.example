# 🚂 VARIABLES D'ENVIRONNEMENT POUR RAILWAY
# Copiez ces variables dans Railway Dashboard → Variables

# ===== REQUIS =====
NODE_ENV=production
MIGRATIONS_AUTO_RUN=true
NPM_CONFIG_PRODUCTION=false

# Session Secret (CHANGEZ CETTE VALEUR!)
# Utilisez un texte long et aléatoire (minimum 32 caractères)
SESSION_SECRET=votre-secret-ultra-securise-changez-moi-123456789

# ===== AUTO-CONFIGURÉES PAR RAILWAY =====
# Railway ajoute automatiquement DATABASE_URL quand vous ajoutez PostgreSQL
# Vous n'avez PAS besoin de les ajouter manuellement :
# DATABASE_URL=postgresql://...  (Railway le fait automatiquement)
# PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE (Railway les ajoute aussi)

# ===== OPTIONNEL (POUR STRIPE) =====
# Ajoutez ces variables seulement si vous voulez activer les paiements Stripe
# STRIPE_SECRET_KEY=sk_live_... (ou sk_test_... pour les tests)
# VITE_STRIPE_PUBLIC_KEY=pk_live_... (ou pk_test_... pour les tests)

# ===== NOTES IMPORTANTES =====
# 1. SESSION_SECRET : CHANGEZ LA VALEUR PAR DÉFAUT !
# 2. DATABASE_URL : Railway la configure automatiquement
# 3. NPM_CONFIG_PRODUCTION=false : Nécessaire pour installer drizzle-kit
# 4. MIGRATIONS_AUTO_RUN=true : Lance les migrations au démarrage
