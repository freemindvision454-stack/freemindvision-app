{
  "name": "freemind-vision",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",

  "main": "server/dist/index.js",

  "scripts": {
    "dev": "tsx server/index.ts",
    "build:server": "tsc -p server/tsconfig.json",
    "build:client": "vite build --outDir server/dist/public",
    "build": "npm run build:server && npm run build:client",
    "start": "node server/dist/index.js",
    "postinstall": "npm run build",
    "check": "tsc",
    "db:push": "drizzle-kit push"
  },

  "files": [
    "server/dist",
    "package.json"
  ],

  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.0",
    "pg": "^8.16.3",
    "bcrypt": "^6.0.0",
    "multer": "^2.0.2",
    "cookie": "^1.0.2",
    "express-session": "^1.18.1",
    "drizzle-orm": "^0.39.1",

    "react": "^18.3.1",
    "react-dom": "^18.3.1",

    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0",

    "cloudinary": "^2.8.0",
    "stripe": "^19.2.1",
    "@supabase/supabase-js": "^2.45.0",

    "trtc-js-sdk": "4.17.7",

    "@neondatabase/serverless": "^0.10.4"
  },

  "devDependencies": {
    "typescript": "5.6.3",
    "tsx": "^4.20.5",
    "vite": "^5.4.20",
    "@vitejs/plugin-react": "^4.7.0",

    "@types/node": "20.16.11",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.13",
    "@types/multer": "^2.0.0",
    "@types/express-session": "^1.18.0",
    "@types/cookie": "^0.6.0",

    "tailwindcss": "^3.4.17",
    "@tailwindcss/vite": "^4.1.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",

    "drizzle-kit": "^0.31.4"
  },

  "engines": {
    "node": ">=20.0.0"
  },

  "engineStrict": false
}
